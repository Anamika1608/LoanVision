{
  "name": "template-drizzle-typescript-zod",
  "version": "1.0.0",
  "description": "Template",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch ./src/index.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun ./dist/index.js",
    "migration:generate": "drizzle-kit generate:pg --schema=./src/model",
    "migration:push": "drizzle-kit push:pg",
    "migrate": "drizzle-kit generate:pg --schema=./src/model && drizzle-kit push:pg"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "colors": "^1.4.0",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.20.14",
    "drizzle-orm": "^0.30.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "nanoid": "^5.1.11",
    "pg": "^8.11.3",
    "postgres": "^3.4.4",
    "redis": "^4.6.13",
    "socket.io": "^4.8.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.11.4",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-react": "^7.34.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.3"
  }
}
